{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openclaw.ai/schemas/clawrouter/service-provider.v1.json",
  "title": "ClawRouter Service Provider Manifest",
  "type": "object",
  "required": ["schema", "id", "displayName", "auth", "baseUrls", "capabilities", "endpoints"],
  "additionalProperties": false,
  "properties": {
    "schema": { "const": "clawrouter.service-provider.v1" },
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
    "displayName": { "type": "string" },
    "description": { "type": "string" },
    "tags": { "type": "array", "items": { "type": "string" } },
    "status": { "enum": ["experimental", "stable", "deprecated", "disabled"] },
    "class": {
      "enum": [
        "openai_compatible",
        "anthropic_compatible",
        "rest_json",
        "rest_form",
        "oauth_rest_json",
        "cloudflare_ai_gateway",
        "custom_adapter"
      ]
    },
    "service": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "platform": { "type": "string" },
        "kind": {
          "enum": [
            "api_provider",
            "model_provider",
            "tool_provider",
            "oauth_platform",
            "metering_platform",
            "gateway_platform"
          ]
        },
        "upstreamService": { "type": "string" },
        "oauthProvider": { "type": "string" },
        "configKeys": { "type": "array", "items": { "type": "string" } },
        "optionalConfigKeys": { "type": "array", "items": { "type": "string" } }
      }
    },
    "auth": {
      "type": "object",
      "required": ["schemes"],
      "additionalProperties": false,
      "properties": {
        "schemes": {
          "type": "array",
          "items": { "$ref": "#/$defs/authScheme" },
          "minItems": 1
        },
        "authorization": {
          "$ref": "#/$defs/authAuthorization"
        },
        "refresh": {
          "$ref": "#/$defs/authRefresh"
        },
        "grantTransports": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/grantTransport" }
        }
      }
    },
    "baseUrls": {
      "type": "object",
      "required": ["default"],
      "additionalProperties": { "type": "string" }
    },
    "routing": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "nativePrefixes": { "type": "array", "items": { "type": "string" } },
        "modelPrefixes": { "type": "array", "items": { "type": "string" } },
        "baseUrlParam": { "type": "string" },
        "serviceParam": { "type": "string" }
      }
    },
    "adapter": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "request": { "type": "string" },
        "response": { "type": "string" },
        "stream": { "type": "string" },
        "error": { "type": "string" },
        "passthroughHeaders": { "type": "array", "items": { "type": "string" } },
        "injectHeaders": { "type": "object", "additionalProperties": { "type": "string" } },
        "injectQuery": { "type": "object", "additionalProperties": { "type": "string" } },
        "requestTransforms": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "renameFields": {
              "type": "array",
              "items": { "$ref": "#/$defs/fieldRenameTransform" }
            }
          }
        }
      }
    },
    "capabilities": {
      "type": "array",
      "items": { "$ref": "#/$defs/capability" },
      "minItems": 1
    },
    "endpoints": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/endpoint" },
      "minProperties": 1
    },
    "models": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "entries": {
          "type": "array",
          "items": { "$ref": "#/$defs/model" }
        }
      }
    },
    "billing": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "meter": { "type": "string" },
        "dimensions": { "type": "array", "items": { "type": "string" } },
        "counters": {
          "type": "array",
          "items": { "$ref": "#/$defs/meterCounter" }
        }
      }
    },
    "tests": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "fixtures": {
          "type": "array",
          "items": { "$ref": "#/$defs/fixture" }
        }
      }
    }
  },
  "$defs": {
    "authAuthorization": {
      "type": "object",
      "required": ["authorizeUrl", "tokenUrl", "scopes"],
      "additionalProperties": false,
      "anyOf": [
        { "required": ["clientId"] },
        { "required": ["clientIdConfig"] }
      ],
      "properties": {
        "authorizeUrl": { "type": "string", "pattern": "^https://" },
        "tokenUrl": { "type": "string", "pattern": "^https://" },
        "clientId": { "type": "string" },
        "clientIdConfig": { "type": "string" },
        "clientSecretConfig": { "type": "string" },
        "scopes": { "type": "array", "items": { "type": "string" } },
        "grantKind": { "enum": ["oauth", "subscription"] },
        "extraAuthorizeParams": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "extraTokenParams": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "accountIdJsonPointer": { "type": "string", "pattern": "^/" },
        "subscriptionPlanJsonPointer": { "type": "string", "pattern": "^/" }
      }
    },
    "authRefresh": {
      "type": "object",
      "required": ["tokenUrl"],
      "additionalProperties": false,
      "anyOf": [
        { "required": ["clientId"] },
        { "required": ["clientIdConfig"] }
      ],
      "properties": {
        "tokenUrl": { "type": "string", "pattern": "^https://" },
        "clientId": { "type": "string" },
        "clientIdConfig": { "type": "string" },
        "clientSecretConfig": { "type": "string" },
        "extraParams": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    },
    "grantTransport": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "baseUrl": { "type": "string", "pattern": "^https://" },
        "endpointPaths": {
          "type": "object",
          "additionalProperties": { "type": "string", "pattern": "^/" }
        },
        "headers": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    },
    "authScheme": {
      "oneOf": [
        {
          "type": "object",
          "required": ["type", "header", "format", "secretKind"],
          "properties": {
            "type": { "const": "bearer" },
            "header": { "type": "string" },
            "format": { "type": "string" },
            "secretKind": { "type": "string" },
            "required": { "type": "boolean", "default": true }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["type", "header", "secretKind"],
          "properties": {
            "type": { "const": "api_key" },
            "header": { "type": "string" },
            "secretKind": { "type": "string" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["type", "param", "secretKind"],
          "properties": {
            "type": { "const": "query_api_key" },
            "param": { "type": "string" },
            "secretKind": { "type": "string" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["type", "scopes"],
          "properties": {
            "type": { "const": "oauth" },
            "provider": { "type": "string" },
            "scopes": { "type": "array", "items": { "type": "string" } },
            "tokenRef": { "type": "string" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["type", "service"],
          "properties": {
            "type": { "const": "sig_v4" },
            "service": { "type": "string" },
            "regionParam": { "type": "string" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["type"],
          "properties": {
            "type": { "const": "cloudflare_binding" }
          },
          "additionalProperties": false
        }
      ]
    },
    "capability": {
      "type": "object",
      "required": ["id", "endpoint"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "endpoint": { "type": "string" },
        "methods": { "type": "array", "items": { "type": "string" } }
      }
    },
    "endpoint": {
      "type": "object",
      "required": ["path", "requestFormat", "responseFormat"],
      "additionalProperties": false,
      "properties": {
        "path": { "type": "string", "pattern": "^/" },
        "method": { "type": "string" },
        "nativeProxy": { "type": "boolean" },
        "auth": { "type": "string" },
        "headers": { "type": "object", "additionalProperties": { "type": "string" } },
        "requestHeaders": { "type": "array", "items": { "type": "string" } },
        "responseHeaders": { "type": "array", "items": { "type": "string" } },
        "query": { "type": "object", "additionalProperties": { "type": "string" } },
        "pathParams": { "type": "array", "items": { "type": "string" } },
        "pathParamStyles": {
          "type": "object",
          "additionalProperties": { "enum": ["segment", "relative_path"] }
        },
        "requestFormat": { "type": "string" },
        "responseFormat": { "type": "string" },
        "streaming": { "type": "string" },
        "timeoutMs": { "type": "integer", "minimum": 1 }
      }
    },
    "model": {
      "type": "object",
      "required": ["id", "upstream"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "upstream": { "type": "string" },
        "capabilities": { "type": "array", "items": { "type": "string" } },
        "pricingRef": { "type": "string" },
        "pricing": { "$ref": "#/$defs/modelPricing" }
      }
    },
    "modelPricing": {
      "type": "object",
      "required": [
        "effectiveAt",
        "source",
        "inputMicrosPerMillion",
        "outputMicrosPerMillion",
        "maxInputTokens",
        "defaultMaxOutputTokens"
      ],
      "additionalProperties": false,
      "properties": {
        "effectiveAt": { "type": "string", "format": "date" },
        "source": { "type": "string", "pattern": "^https://" },
        "inputMicrosPerMillion": { "type": "integer", "minimum": 0 },
        "outputMicrosPerMillion": { "type": "integer", "minimum": 0 },
        "cachedInputMicrosPerMillion": { "type": "integer", "minimum": 0 },
        "cacheWrite5mInputMicrosPerMillion": { "type": "integer", "minimum": 0 },
        "cacheWrite1hInputMicrosPerMillion": { "type": "integer", "minimum": 0 },
        "maxInputTokens": { "type": "integer", "minimum": 1 },
        "maxRequestInputTokens": { "type": "integer", "minimum": 1 },
        "defaultMaxOutputTokens": { "type": "integer", "minimum": 0 },
        "inputTokenOverhead": { "type": "integer", "minimum": 0 },
        "longContext": { "$ref": "#/$defs/longContextPricing" }
      }
    },
    "longContextPricing": {
      "type": "object",
      "required": [
        "thresholdInputTokens",
        "inputMicrosPerMillion",
        "outputMicrosPerMillion"
      ],
      "additionalProperties": false,
      "properties": {
        "thresholdInputTokens": { "type": "integer", "minimum": 1 },
        "inputMicrosPerMillion": { "type": "integer", "minimum": 0 },
        "outputMicrosPerMillion": { "type": "integer", "minimum": 0 },
        "cachedInputMicrosPerMillion": { "type": "integer", "minimum": 0 },
        "cacheWrite5mInputMicrosPerMillion": { "type": "integer", "minimum": 0 },
        "cacheWrite1hInputMicrosPerMillion": { "type": "integer", "minimum": 0 }
      }
    },
    "meterCounter": {
      "type": "object",
      "required": ["name", "source"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "source": { "type": "string" },
        "unit": { "type": "string" }
      }
    },
    "fieldRenameTransform": {
      "type": "object",
      "required": ["from", "to"],
      "additionalProperties": false,
      "properties": {
        "from": { "type": "string" },
        "to": { "type": "string" },
        "paths": { "type": "array", "items": { "type": "string" } },
        "upstreams": { "type": "array", "items": { "type": "string" } },
        "upstreamConfig": { "type": "string" }
      }
    },
    "fixture": {
      "type": "object",
      "required": ["name", "request", "response"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "request": { "type": "string" },
        "response": { "type": "string" }
      }
    }
  }
}
